# Snowflake Connection Configuration
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# Snowflake Account (e.g., your-org.eu-west-1 or xy12345)
SNOWFLAKE_ACCOUNT=your-account-here

# Snowflake Username
SNOWFLAKE_USER=your-username-here

# Snowflake Role (ANALYST role for generic analytics)
SNOWFLAKE_ROLE=ANALYST

# Snowflake Warehouse (e.g., NCL_ANALYTICS_XS)
SNOWFLAKE_WAREHOUSE=your-warehouse-here

# Optional: Snowflake Programmatic Access Token (recommended for Codespaces)
# When set, dbt uses this as the password and skips browser-based login.
# SNOWFLAKE_PAT=your-programmatic-access-token

# Optional: Snowflake Password
# SNOWFLAKE_PASSWORD=your-password-here

# Optional: Override authenticator when needed (defaults to externalbrowser
# unless SNOWFLAKE_PAT / SNOWFLAKE_PASSWORD is set, then defaults to snowflake)
# SNOWFLAKE_AUTHENTICATOR=
