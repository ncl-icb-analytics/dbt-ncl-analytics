{
  "name": "dbt-ncl-analytics",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python"
      },
      "extensions": [
        "innoverio.vscode-dbt-power-user",
        "charliermarsh.ruff",
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    },
    "codespaces": {
      "openFiles": [
        "README.md",
        "CONTRIBUTING.md"
      ]
    }
  },
  "secrets": {
    "SNOWFLAKE_ACCOUNT": {
      "description": "Snowflake account identifier for dbt development."
    },
    "SNOWFLAKE_USER": {
      "description": "Snowflake username for dbt development."
    },
    "SNOWFLAKE_ROLE": {
      "description": "Snowflake role to use in the codespace, for example ANALYST."
    },
    "SNOWFLAKE_WAREHOUSE": {
      "description": "Snowflake warehouse to use in the codespace."
    },
    "SNOWFLAKE_PAT": {
      "description": "Snowflake Programmatic Access Token used as the password in Codespaces."
    }
  }
}
